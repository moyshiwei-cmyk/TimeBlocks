<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>TimeFlow — Time Management</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#FAF7F2;--sb-bg:#F0EBE3;--sb-hover:#E6DED5;
  --accent:#B87333;--accent2:#D49A6A;--text:#2C2420;--muted:#9C8B82;
  --border:#DDD6CC;--ws-bg:#F5F0E8;--sh:rgba(44,36,32,.10);
  --row-h:66px;--left-w:178px
}
html,body{height:100%;font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);overflow:hidden}
#app{display:flex;height:100vh;width:100vw}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

/* ═══ LEFT PANEL ═══ */
#left-panel{display:flex;flex-shrink:0;transition:width .28s cubic-bezier(.4,0,.2,1)}

.sidebar{height:100vh;overflow-y:auto;background:var(--sb-bg);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
#year-sidebar{width:var(--left-w);transition:width .28s cubic-bezier(.4,0,.2,1);overflow:hidden}
#year-sidebar.collapsed{width:38px;overflow:hidden}
#year-sidebar.collapsed .sb-content{opacity:0;pointer-events:none}

#date-sidebar{width:0;overflow:hidden;transition:width .28s cubic-bezier(.4,0,.2,1)}
#date-sidebar.open{width:150px;border-right:1px solid var(--border)}

.sb-head{
  padding:14px 11px 11px;font-family:'Playfair Display',serif;font-size:11px;
  letter-spacing:.14em;text-transform:uppercase;color:var(--muted);
  border-bottom:1px solid var(--border);display:flex;align-items:center;
  justify-content:space-between;flex-shrink:0;position:sticky;top:0;background:var(--sb-bg);z-index:3;
  min-height:42px
}
.sb-head-title{white-space:nowrap;overflow:hidden;transition:opacity .2s}
.sb-toggle{
  width:22px;height:22px;border-radius:5px;border:none;
  background:var(--border);color:var(--muted);cursor:pointer;font-size:13px;
  display:flex;align-items:center;justify-content:center;
  transition:background .15s,color .15s,transform .25s;flex-shrink:0
}
.sb-toggle:hover{background:var(--accent);color:#fff}
#year-sidebar.collapsed .sb-toggle{transform:rotate(180deg)}
.sb-content{transition:opacity .22s}

.sb-close{width:20px;height:20px;border-radius:50%;border:none;background:var(--border);color:var(--muted);cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;transition:background .15s,color .15s}
.sb-close:hover{background:var(--accent);color:#fff}

.year-group{border-bottom:1px solid var(--border)}
.year-label{padding:8px 11px;font-family:'DM Mono',monospace;font-size:12px;font-weight:500;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:background .12s;user-select:none;color:var(--text)}
.year-label:hover{background:var(--sb-hover)}
.year-label.cur-yr{color:var(--accent);font-weight:600}
.year-label .chev{font-size:9px;transition:transform .2s;color:var(--muted)}
.year-label.expanded .chev{transform:rotate(180deg)}
.month-list{display:none;background:var(--bg)}
.month-list.open{display:block}
.month-item{padding:5px 11px 5px 20px;font-size:11px;cursor:pointer;color:var(--muted);transition:all .12s;border-left:2px solid transparent}
.month-item:hover{color:var(--text);background:var(--sb-hover);border-left-color:var(--accent2)}
.month-item.sel-month{color:var(--accent);border-left-color:var(--accent);font-weight:500}
.month-item.cur-month{font-style:italic}

#date-sidebar-inner{width:150px}
.ds-month-label{padding:6px 11px;font-size:9.5px;color:var(--muted);font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:.1em;border-bottom:1px solid var(--border);background:var(--sb-bg)}
.day-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;padding:6px 4px 8px}
.day-hdr{font-size:7.5px;text-align:center;color:var(--muted);font-weight:700;padding:2px 0;letter-spacing:.04em}
.day-cell{aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:9px;font-family:'DM Mono',monospace;border-radius:3px;cursor:pointer;transition:background .1s,color .1s;color:var(--text)}
.day-cell:not(.empty):hover{background:var(--accent);color:#fff}
.day-cell.today{background:var(--accent);color:#fff;font-weight:700}
.day-cell.empty{cursor:default}

/* ═══ WORKSPACE ═══ */
#workspace{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}

/* ── TOOLBAR ── */
#toolbar{
  flex-shrink:0;display:flex;align-items:center;
  background:var(--bg);border-bottom:1px solid var(--border);
  padding:0 16px;gap:4px;height:44px;z-index:30
}
#app-title{font-family:'Playfair Display',serif;font-size:18px;color:var(--muted);opacity:.45;letter-spacing:.02em;margin-right:14px;flex-shrink:0}
.tab-btn{
  padding:6px 16px;border:none;background:none;font-family:'DM Sans',sans-serif;
  font-size:12.5px;font-weight:500;cursor:pointer;border-radius:6px;
  color:var(--muted);transition:all .15s;position:relative
}
.tab-btn:hover{color:var(--text);background:var(--sb-hover)}
.tab-btn.active{color:var(--accent);background:rgba(184,115,51,.10)}
.tab-btn.active::after{content:'';position:absolute;bottom:-1px;left:16px;right:16px;height:2px;background:var(--accent);border-radius:2px 2px 0 0}

#date-display{font-family:'DM Mono',monospace;font-size:10.5px;color:var(--accent);font-weight:500;margin-left:8px}

#streak-widget{margin-left:auto;display:flex;align-items:center;gap:9px;background:linear-gradient(135deg,#fff8f3,#fef0e4);border:1px solid #f0d5b8;border-radius:10px;padding:5px 12px;box-shadow:0 2px 8px rgba(184,115,51,.07)}
.sw-fire{font-size:18px;line-height:1}
.sw-info{display:flex;flex-direction:column;gap:1px}
.sw-line1{display:flex;align-items:center;gap:5px;font-size:11.5px;font-weight:600;color:var(--text)}
.sw-streak-val{font-family:'DM Mono',monospace;font-size:14px;color:var(--accent);font-weight:700}
.sw-score-wrap{display:flex;align-items:center;gap:3px}
.sw-score-val{font-family:'DM Mono',monospace;font-size:12px;color:#6a5acd;font-weight:700}
.sw-score-lbl{font-size:10px;color:var(--muted)}
.sw-bar-wrap{height:3px;background:#e8ddd5;border-radius:2px;width:80px;overflow:hidden}
.sw-bar-fill{height:100%;background:linear-gradient(90deg,var(--accent2),var(--accent));border-radius:2px;transition:width .5s ease}
.sw-next{font-size:9px;color:var(--muted);letter-spacing:.02em}

/* ── VIEW PANELS ── */
#view-main,#view-analytics{display:none;flex:1;overflow:hidden;flex-direction:column}
#view-main.active,#view-analytics.active{display:flex}

/* ── MAIN VIEW ── */
#ws-scroll{flex:1;overflow-y:auto;overflow-x:hidden;display:flex;position:relative}
#time-col{flex-shrink:0;width:56px;background:var(--bg);border-right:1px solid var(--border);height:calc(var(--row-h)*24)}
.time-label{height:var(--row-h);display:flex;align-items:flex-start;justify-content:flex-end;padding:5px 7px 0 0;font-family:'DM Mono',monospace;font-size:9px;color:var(--muted);border-bottom:1px solid var(--border)}
.time-label.cur-time-row{color:var(--accent);font-weight:700}
#grid-area{flex:1;position:relative;height:calc(var(--row-h)*24);min-width:200px}
.grid-row{position:absolute;left:0;right:0;height:var(--row-h);border-bottom:1px solid rgba(200,190,180,.4)}
.grid-row:nth-child(odd){background:rgba(255,255,255,.35)}
.grid-row:nth-child(even){background:rgba(220,210,200,.1)}
.grid-row.cur-hr-row{background:rgba(184,115,51,.07)}
#now-line{position:absolute;left:0;right:0;height:2px;background:var(--accent);z-index:8;pointer-events:none;display:flex;align-items:center}
#now-line::before{content:'';width:8px;height:8px;border-radius:50%;background:var(--accent);margin-left:-4px;flex-shrink:0}

/* ═══ BLOCKS ═══ */
.block{
  position:absolute;min-width:130px;width:220px;height:calc(var(--row-h) - 6px);
  border-radius:7px;padding:7px 26px 7px 10px;cursor:move;
  box-shadow:0 2px 10px var(--sh);user-select:none;overflow:visible;
  transition:box-shadow .15s,transform .12s,width .2s ease,height .2s ease;z-index:10
}
.block:hover{box-shadow:0 6px 20px rgba(44,36,32,.15);z-index:20}
.block.dragging{
  box-shadow:0 18px 40px rgba(44,36,32,.26);z-index:100;opacity:.93;
  transform:rotate(.5deg) scale(1.06) !important;
  transition:box-shadow .15s,transform .15s !important
}
.block-resize{position:absolute;bottom:3px;right:3px;width:10px;height:10px;cursor:se-resize;opacity:.3;background-image:repeating-linear-gradient(135deg,currentColor 0 1.5px,transparent 0 3px);background-size:6px 6px}
.block:hover .block-resize{opacity:.6}
.block-text{outline:none;font-family:'DM Sans',sans-serif;font-size:12px;line-height:1.5;min-height:22px;word-break:break-word;cursor:text;height:100%;overflow:auto}
.block-text:empty::before{content:attr(data-ph);opacity:.32;pointer-events:none}
.block-menu-btn{position:absolute;top:4px;right:4px;width:19px;height:19px;border-radius:4px;border:none;background:rgba(128,128,128,.16);cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .15s,background .12s;z-index:3;line-height:1}
.block:hover .block-menu-btn{opacity:1}
.block-menu-btn:hover{background:rgba(128,128,128,.32)}

/* ═══ DROPDOWN PORTAL ═══ */
#dd-portal{position:fixed;z-index:9999;top:0;left:0;pointer-events:none}
.block-dropdown{position:fixed;pointer-events:all;background:#fff;border:1px solid #e0d8d0;border-radius:12px;box-shadow:0 12px 36px rgba(0,0,0,.16),0 2px 8px rgba(0,0,0,.06);padding:14px;width:238px;animation:ddIn .14s ease}
@keyframes ddIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
.dd-section-title{font-size:9px;text-transform:uppercase;letter-spacing:.14em;color:var(--muted);margin-bottom:8px;font-family:'Playfair Display',serif}
.dd-swatches{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:2px}
.dd-swatch{width:26px;height:26px;border-radius:6px;cursor:pointer;border:2.5px solid transparent;transition:transform .1s,border-color .1s,box-shadow .1s}
.dd-swatch:hover{transform:scale(1.18);box-shadow:0 3px 8px rgba(0,0,0,.18)}
.dd-swatch.cur-sw{border-color:#333;box-shadow:0 0 0 2px rgba(0,0,0,.12)}
.dd-divider{border:none;border-top:1px solid #ede8e2;margin:9px 0}
.dd-btn{width:100%;text-align:left;padding:7px 10px;border:none;background:none;font-family:'DM Sans',sans-serif;font-size:12.5px;cursor:pointer;border-radius:6px;display:flex;align-items:center;gap:9px;transition:background .1s;color:var(--text)}
.dd-btn:hover{background:#f5f0e8}
.dd-btn.danger{color:#c0392b}
.dd-btn.danger:hover{background:#fde8e6}
.dd-btn-icon{font-size:14px;width:18px;text-align:center;flex-shrink:0}
.dd-cat{font-size:8.5px;text-transform:uppercase;letter-spacing:.1em;color:#b0a090;margin:7px 0 5px;font-weight:600}
.dd-cat:first-child{margin-top:2px}

/* ═══ RIGHT SIDEBAR ═══ */
#right-sidebar{width:214px;flex-shrink:0;height:100vh;overflow-y:auto;background:var(--sb-bg);border-left:1px solid var(--border);display:flex;flex-direction:column}
.rs-head{padding:14px 12px 10px;border-bottom:1px solid var(--border);background:var(--sb-bg);position:sticky;top:0;z-index:3}
.rs-head h2{font-family:'Playfair Display',serif;font-size:16px;font-weight:600}
.rs-head p{font-size:9.5px;color:var(--muted);margin-top:2px}
.rs-section{padding:12px;border-bottom:1px solid var(--border)}
.rs-section-title{font-size:9.5px;text-transform:uppercase;letter-spacing:.13em;color:var(--muted);margin-bottom:9px;font-family:'Playfair Display',serif}

/* Colour swatches — draggable */
.colour-cat{font-size:8.5px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin:8px 0 5px;font-weight:600}
.colour-cat:first-child{margin-top:0}
.colour-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:5px}
.colour-swatch{
  height:34px;border-radius:7px;cursor:grab;
  border:2.5px solid transparent;transition:transform .12s,border-color .12s,box-shadow .12s;
  position:relative;display:flex;align-items:center;justify-content:center
}
.colour-swatch:hover{transform:translateY(-3px) scale(1.06);box-shadow:0 6px 14px var(--sh)}
.colour-swatch:active{cursor:grabbing}
.colour-swatch.sel{border-color:#333;box-shadow:0 4px 10px var(--sh)}
.colour-swatch .tick{position:absolute;inset:0;display:none;align-items:center;justify-content:center;font-size:11px}
.colour-swatch.sel .tick{display:flex}
.cs-grab-hint{font-size:8px;opacity:.4;pointer-events:none;line-height:1}

/* Presets */
.preset-item{background:#fff;border:1px solid var(--border);border-radius:7px;padding:6px 8px;margin-bottom:5px;display:flex;align-items:center;gap:7px;cursor:grab;transition:box-shadow .14s}
.preset-item:hover{box-shadow:0 3px 10px var(--sh)}
.preset-item:active{cursor:grabbing}
.preset-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;border:1px solid rgba(0,0,0,.08)}
.preset-txt{font-size:11px;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text)}
.preset-del{width:16px;height:16px;border:none;background:none;cursor:pointer;color:var(--muted);font-size:14px;display:flex;align-items:center;justify-content:center;border-radius:3px;opacity:0;transition:all .1s;flex-shrink:0;line-height:1}
.preset-item:hover .preset-del{opacity:1}
.preset-del:hover{background:#ff5252;color:#fff}
.no-presets{font-size:10.5px;color:var(--muted);text-align:center;padding:12px 6px;font-style:italic;line-height:1.7}

/* ═══ ANALYTICS VIEW ═══ */
#view-analytics{background:var(--ws-bg);padding:0;overflow-y:auto}
.analytics-inner{padding:28px 32px;max-width:920px;margin:0 auto}
.an-title{font-family:'Playfair Display',serif;font-size:22px;font-weight:600;margin-bottom:4px}
.an-sub{font-size:12px;color:var(--muted);margin-bottom:28px}

.an-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
.an-card{background:#fff;border:1px solid var(--border);border-radius:14px;padding:20px;box-shadow:0 2px 12px var(--sh)}
.an-card-title{font-family:'Playfair Display',serif;font-size:14px;font-weight:600;margin-bottom:4px;color:var(--text)}
.an-card-sub{font-size:10.5px;color:var(--muted);margin-bottom:16px}
.an-card.full{grid-column:1/-1}

/* Pie chart */
#pie-wrap{display:flex;align-items:center;gap:28px;flex-wrap:wrap}
#pie-canvas{flex-shrink:0}
#pie-legend{display:flex;flex-direction:column;gap:8px;flex:1;min-width:140px}
.legend-item{display:flex;align-items:center;gap:8px;font-size:11.5px}
.legend-dot{width:11px;height:11px;border-radius:3px;flex-shrink:0}
.legend-label{flex:1;color:var(--text)}
.legend-pct{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted);font-weight:500}
.legend-hrs{font-family:'DM Mono',monospace;font-size:10px;color:var(--muted)}

/* Stat cards */
.stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px}
.stat-card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center;box-shadow:0 2px 8px var(--sh)}
.stat-val{font-family:'DM Mono',monospace;font-size:24px;font-weight:700;color:var(--accent)}
.stat-lbl{font-size:10.5px;color:var(--muted);margin-top:3px}

/* Bar chart */
#bar-chart{display:flex;align-items:flex-end;gap:6px;height:120px;padding-bottom:24px;position:relative}
.bar-col{display:flex;flex-direction:column;align-items:center;flex:1;height:100%;justify-content:flex-end}
.bar-fill{width:100%;border-radius:4px 4px 0 0;transition:height .6s ease;min-height:2px;position:relative}
.bar-fill:hover::after{content:attr(data-tip);position:absolute;top:-26px;left:50%;transform:translateX(-50%);background:#333;color:#fff;font-size:9px;padding:2px 6px;border-radius:4px;white-space:nowrap;pointer-events:none}
.bar-lbl{font-size:8px;color:var(--muted);margin-top:5px;font-family:'DM Mono',monospace;text-align:center}

.an-empty{text-align:center;padding:40px 20px;color:var(--muted);font-size:13px;font-style:italic;line-height:1.8}
.an-empty-icon{font-size:36px;margin-bottom:8px;opacity:.4}

/* ═══ TOAST & MILESTONE ═══ */
#toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%) translateY(14px);background:var(--text);color:#FAF7F2;padding:7px 17px;border-radius:22px;font-size:12px;opacity:0;transition:opacity .25s,transform .25s;z-index:10000;pointer-events:none;white-space:nowrap}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
#milestone-popup{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(.7);background:#fff;border:1.5px solid #f0d5b8;border-radius:18px;padding:26px 34px;text-align:center;z-index:10001;box-shadow:0 24px 60px rgba(0,0,0,.18);opacity:0;transition:opacity .3s,transform .3s;pointer-events:none}
#milestone-popup.show{opacity:1;transform:translate(-50%,-50%) scale(1);pointer-events:all}
.mp-emoji{font-size:40px;margin-bottom:8px}
.mp-title{font-family:'Playfair Display',serif;font-size:21px;font-weight:600;color:var(--text)}
.mp-sub{font-size:12.5px;color:var(--muted);margin-top:5px}
.mp-score{font-family:'DM Mono',monospace;font-size:27px;color:#6a5acd;font-weight:700;margin:10px 0}
.mp-close{margin-top:12px;padding:7px 22px;background:var(--accent);color:#fff;border:none;border-radius:20px;font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background .15s}
.mp-close:hover{background:var(--accent2)}
</style>
</head>
<body>
<div id="app">

<!-- LEFT PANEL -->
<div id="left-panel">
  <div class="sidebar" id="year-sidebar">
    <div class="sb-head">
      <span class="sb-head-title">Calendar</span>
      <button class="sb-toggle" id="cal-toggle" title="Minimise calendar" onclick="toggleCalendar()">◀</button>
    </div>
    <div class="sb-content" id="year-list"></div>
  </div>

  <div class="sidebar" id="date-sidebar">
    <div id="date-sidebar-inner">
      <div class="sb-head">
        <span id="ds-label">Dates</span>
        <button class="sb-close" onclick="closeDateSidebar()">×</button>
      </div>
      <div class="ds-month-label" id="ds-month-info"></div>
      <div class="day-grid" id="day-grid"></div>
    </div>
  </div>
</div>

<!-- WORKSPACE -->
<div id="workspace">

  <!-- TOOLBAR -->
  <div id="toolbar">
    <span id="app-title">TimeFlow</span>
    <button class="tab-btn active" id="tab-main" onclick="switchTab('main')">Main</button>
    <button class="tab-btn" id="tab-analytics" onclick="switchTab('analytics')">Analytics</button>
    <span id="date-display"></span>
    <div id="streak-widget">
      <div class="sw-fire" id="streak-fire">🔥</div>
      <div class="sw-info">
        <div class="sw-line1">
          <span class="sw-streak-val" id="streak-count">0</span>
          <span style="color:var(--muted);font-size:10.5px">day streak</span>
          <span style="color:var(--muted);margin:0 2px">·</span>
          <div class="sw-score-wrap">
            <span style="font-size:12px">⭐</span>
            <span class="sw-score-val" id="streak-score">0</span>
            <span class="sw-score-lbl">pts</span>
          </div>
        </div>
        <div class="sw-bar-wrap"><div class="sw-bar-fill" id="streak-bar"></div></div>
        <div class="sw-next" id="streak-next">Place a block to start your streak!</div>
      </div>
    </div>
  </div>

  <!-- MAIN VIEW -->
  <div id="view-main" class="active">
    <div id="ws-scroll">
      <div id="time-col"></div>
      <div id="grid-area"><div id="now-line"></div></div>
    </div>
  </div>

  <!-- ANALYTICS VIEW -->
  <div id="view-analytics">
    <div class="analytics-inner" id="analytics-inner"></div>
  </div>

</div><!-- #workspace -->

<!-- RIGHT SIDEBAR -->
<div id="right-sidebar">
  <div class="rs-head">
    <h2>Blocks</h2>
    <p>Drag any colour directly to workspace</p>
  </div>

  <div class="rs-section">
    <div class="rs-section-title">Colour & Drag</div>
    <div class="colour-cat">Comforting</div>
    <div class="colour-grid" id="comfort-grid"></div>
    <div class="colour-cat">Strong</div>
    <div class="colour-grid" id="strong-grid"></div>
  </div>

  <div class="rs-section" style="flex:1;min-height:100px">
    <div class="rs-section-title">Saved Presets</div>
    <div id="presets-list"></div>
  </div>
</div>

</div><!-- #app -->

<div id="dd-portal"></div>
<div id="toast"></div>
<div id="milestone-popup">
  <div class="mp-emoji">🏆</div>
  <div class="mp-title" id="mp-title">Streak Milestone!</div>
  <div class="mp-sub" id="mp-sub">You've been scheduling for 10 days in a row</div>
  <div class="mp-score" id="mp-score">+1,000 pts</div>
  <button class="mp-close" onclick="closeMilestone()">Awesome! ✓</button>
</div>

<script>
// ═══════════════════════════════
//  DATA
// ═══════════════════════════════
const MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
const DAYS_SH=['Su','Mo','Tu','We','Th','Fr','Sa'];
const ROW_H=66;

const COMFORT_COLORS=[
  {name:'Sky Blue',hex:'#A8D8EA',fg:'#1C1C1C'},
  {name:'Sage',hex:'#A8C5A0',fg:'#1C1C1C'},
  {name:'Warm Yellow',hex:'#F9E4A0',fg:'#1C1C1C'},
  {name:'Peach',hex:'#FECBA1',fg:'#1C1C1C'},
  {name:'Lavender',hex:'#D8C5E8',fg:'#1C1C1C'},
  {name:'Mint',hex:'#B5EAD7',fg:'#1C1C1C'},
  {name:'Blush',hex:'#F4C2C2',fg:'#1C1C1C'},
  {name:'Cream',hex:'#FAFAE0',fg:'#1C1C1C'},
];
const STRONG_COLORS=[
  {name:'Bright Red',hex:'#FF4444',fg:'#1C1C1C'},
  {name:'Bright Yellow',hex:'#FFE135',fg:'#1C1C1C'},
  {name:'Deep Orange',hex:'#FF7B22',fg:'#1C1C1C'},
  {name:'Black',hex:'#1C1C1C',fg:'#FFFFFF'},
];
const ALL_COLORS=[...COMFORT_COLORS,...STRONG_COLORS];

let presets=JSON.parse(localStorage.getItem('tf_presets')||'[]');
let blockCnt=0;
let dragColor=null; // color being dragged from swatch
const today=new Date();

// ═══════════════════════════════
//  AUDIO — vibration buzz
// ═══════════════════════════════
function playPlaceSound(){
  try{
    const ctx=new(window.AudioContext||window.webkitAudioContext)();
    // Quick buzz: two short pulses
    [0, 0.07].forEach(offset=>{
      const osc=ctx.createOscillator();
      const gain=ctx.createGain();
      osc.connect(gain);gain.connect(ctx.destination);
      osc.type='sawtooth';
      osc.frequency.setValueAtTime(180,ctx.currentTime+offset);
      osc.frequency.exponentialRampToValueAtTime(60,ctx.currentTime+offset+0.06);
      gain.gain.setValueAtTime(0.18,ctx.currentTime+offset);
      gain.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+offset+0.07);
      osc.start(ctx.currentTime+offset);
      osc.stop(ctx.currentTime+offset+0.08);
    });
    setTimeout(()=>ctx.close(),400);
  }catch(e){}
}

// ═══════════════════════════════
//  STREAK
// ═══════════════════════════════
const SK='tf_streak_v3';
function fmtDate(d){return d.toISOString().slice(0,10)}
function getStreak(){return JSON.parse(localStorage.getItem(SK)||JSON.stringify({lastDate:null,count:0,score:0}))}

function checkAndUpdateStreak(){
  const ts=fmtDate(new Date());
  let s=getStreak();
  if(s.lastDate===ts){updateStreakUI(s);return;}
  const prev=s.count;
  const yest=new Date();yest.setDate(yest.getDate()-1);
  s.count=s.lastDate===fmtDate(yest)?s.count+1:1;
  s.lastDate=ts;
  const om=Math.floor(prev/10),nm=Math.floor(s.count/10);
  if(nm>om){const gained=(nm-om)*1000;s.score=(s.score||0)+gained;setTimeout(()=>showMilestone(s.count,gained),700);}
  localStorage.setItem(SK,JSON.stringify(s));
  updateStreakUI(s);
}

function updateStreakUI(s){
  document.getElementById('streak-count').textContent=s.count;
  document.getElementById('streak-score').textContent=(s.score||0).toLocaleString();
  document.getElementById('streak-bar').style.width=((s.count%10)/10*100)+'%';
  const tn=10-(s.count%10);
  document.getElementById('streak-next').textContent=
    tn===10?`🎯 Milestone! Next: ${s.count+10} days`:`${tn} day${tn===1?'':'s'} to +1,000 pts ⭐`;
  document.getElementById('streak-fire').textContent=s.count>=30?'🔥🔥🔥':s.count>=20?'🔥🔥':'🔥';
}

function showMilestone(days,gained){
  document.getElementById('mp-title').textContent=`${days}-Day Streak! 🎉`;
  document.getElementById('mp-sub').textContent=`You've scheduled for ${days} days in a row!`;
  document.getElementById('mp-score').textContent=`+${gained.toLocaleString()} pts`;
  document.getElementById('milestone-popup').classList.add('show');
}
function closeMilestone(){document.getElementById('milestone-popup').classList.remove('show')}

(function(){updateStreakUI(getStreak())})();

// ═══════════════════════════════
//  INIT
// ═══════════════════════════════
function init(){
  buildYearList();
  buildTimeGrid();
  buildColourGrids();
  renderPresets();
  setupGridDrop();
  updateNowLine();
  setInterval(updateNowLine,60000);

  const yl=document.querySelector(`.year-label[data-year="${today.getFullYear()}"]`);
  if(yl){
    const ml=document.getElementById(`months-${today.getFullYear()}`);
    toggleYear(today.getFullYear(),yl,ml);
    setTimeout(()=>{
      const mi=document.querySelector(`.month-item[data-month="${today.getMonth()}"][data-year="${today.getFullYear()}"]`);
      if(mi)mi.click();
    },80);
  }
  document.getElementById('date-display').textContent=`${today.getDate()} ${MONTHS[today.getMonth()]} ${today.getFullYear()}`;
  setTimeout(()=>{document.getElementById('ws-scroll').scrollTop=Math.max(0,today.getHours()*ROW_H-100);},160);
  document.addEventListener('click',()=>closeDD());
}

// ═══════════════════════════════
//  CALENDAR COLLAPSE
// ═══════════════════════════════
function toggleCalendar(){
  const ys=document.getElementById('year-sidebar');
  ys.classList.toggle('collapsed');
  // Also close date sidebar when collapsing
  if(ys.classList.contains('collapsed')) closeDateSidebar();
}

// ═══════════════════════════════
//  TAB SWITCHING
// ═══════════════════════════════
function switchTab(tab){
  document.getElementById('view-main').classList.toggle('active',tab==='main');
  document.getElementById('view-analytics').classList.toggle('active',tab==='analytics');
  document.getElementById('tab-main').classList.toggle('active',tab==='main');
  document.getElementById('tab-analytics').classList.toggle('active',tab==='analytics');
  if(tab==='analytics') renderAnalytics();
}

// ═══════════════════════════════
//  YEAR SIDEBAR
// ═══════════════════════════════
function buildYearList(){
  const container=document.getElementById('year-list');
  const cy=today.getFullYear();
  for(let y=cy-10;y<=cy+10;y++){
    const grp=document.createElement('div');grp.className='year-group';
    const lbl=document.createElement('div');
    lbl.className='year-label'+(y===cy?' cur-yr':'');
    lbl.dataset.year=y;
    lbl.innerHTML=`<span>${y}</span><span class="chev">▾</span>`;
    const ml=document.createElement('div');ml.className='month-list';ml.id=`months-${y}`;
    MONTHS.forEach((m,i)=>{
      const item=document.createElement('div');
      item.className='month-item'+(i===today.getMonth()&&y===cy?' cur-month':'');
      item.dataset.month=i;item.dataset.year=y;item.textContent=m;
      item.addEventListener('click',e=>{e.stopPropagation();selectMonth(y,i,item);});
      ml.appendChild(item);
    });
    lbl.addEventListener('click',()=>toggleYear(y,lbl,ml));
    grp.appendChild(lbl);grp.appendChild(ml);container.appendChild(grp);
  }
}

function toggleYear(y,lbl,ml){
  const isOpen=ml.classList.contains('open');
  document.querySelectorAll('.month-list.open').forEach(el=>el.classList.remove('open'));
  document.querySelectorAll('.year-label.expanded').forEach(el=>el.classList.remove('expanded'));
  if(!isOpen){ml.classList.add('open');lbl.classList.add('expanded');}
}

function selectMonth(year,mi,item){
  document.querySelectorAll('.month-item.sel-month').forEach(el=>el.classList.remove('sel-month'));
  item.classList.add('sel-month');
  openDateSidebar(year,mi);
  document.getElementById('date-display').textContent=`${MONTHS[mi]} ${year}`;
}

function openDateSidebar(year,month){
  document.getElementById('date-sidebar').classList.add('open');
  document.getElementById('ds-label').textContent=MONTHS[month].slice(0,3)+' '+year;
  document.getElementById('ds-month-info').textContent=`${MONTHS[month]} ${year}`;
  buildDayGrid(year,month);
}
function closeDateSidebar(){document.getElementById('date-sidebar').classList.remove('open')}

function buildDayGrid(year,month){
  const grid=document.getElementById('day-grid');grid.innerHTML='';
  DAYS_SH.forEach(d=>{const h=document.createElement('div');h.className='day-hdr';h.textContent=d;grid.appendChild(h);});
  const fd=new Date(year,month,1).getDay(),dim=new Date(year,month+1,0).getDate();
  for(let i=0;i<fd;i++){const c=document.createElement('div');c.className='day-cell empty';grid.appendChild(c);}
  for(let d=1;d<=dim;d++){
    const c=document.createElement('div');c.className='day-cell';
    if(d===today.getDate()&&month===today.getMonth()&&year===today.getFullYear())c.classList.add('today');
    c.textContent=d;
    c.addEventListener('click',()=>{document.getElementById('date-display').textContent=`${d} ${MONTHS[month]} ${year}`;});
    grid.appendChild(c);
  }
}

// ═══════════════════════════════
//  TIME GRID
// ═══════════════════════════════
function buildTimeGrid(){
  const col=document.getElementById('time-col'),grid=document.getElementById('grid-area'),curH=today.getHours(),nl=document.getElementById('now-line');
  for(let h=0;h<24;h++){
    const lbl=document.createElement('div');lbl.className='time-label'+(h===curH?' cur-time-row':'');lbl.textContent=h.toString().padStart(2,'0')+':00';col.appendChild(lbl);
    const row=document.createElement('div');row.className='grid-row'+(h===curH?' cur-hr-row':'');row.style.top=(h*ROW_H)+'px';row.dataset.hour=h;grid.insertBefore(row,nl);
  }
}
function updateNowLine(){
  const now=new Date();
  document.getElementById('now-line').style.top=(( now.getHours()*60+now.getMinutes())/1440*(ROW_H*24))+'px';
}

// ═══════════════════════════════
//  COLOUR GRIDS — draggable swatches
// ═══════════════════════════════
function buildColourGrids(){
  buildColGrid('comfort-grid',COMFORT_COLORS);
  buildColGrid('strong-grid',STRONG_COLORS);
}

function buildColGrid(id,colors){
  const g=document.getElementById(id);
  colors.forEach(col=>{
    const s=document.createElement('div');
    s.className='colour-swatch';
    s.style.background=col.hex;
    if(col.hex==='#FAFAE0')s.style.border='2px solid #ccc';
    s.title=col.name+'\nDrag to workspace';
    s.draggable=true;
    // Tick (not needed for selection anymore, keeping for drag feedback)
    const hint=document.createElement('span');hint.className='cs-grab-hint';hint.textContent='⠿';s.appendChild(hint);
    s.addEventListener('dragstart',e=>{
      dragColor=col;
      e.dataTransfer.setData('text/plain','color-swatch');
      e.dataTransfer.effectAllowed='copy';
    });
    s.addEventListener('dragend',()=>{ dragColor=null; });
    g.appendChild(s);
  });
}

// ═══════════════════════════════
//  DROP onto grid
// ═══════════════════════════════
function setupGridDrop(){
  const grid=document.getElementById('grid-area');
  grid.addEventListener('dragover',e=>{e.preventDefault();e.dataTransfer.dropEffect='copy';});
  grid.addEventListener('drop',e=>{
    e.preventDefault();
    const type=e.dataTransfer.getData('text/plain');
    if(type!=='color-swatch'&&!type.startsWith('preset:'))return;
    const rect=grid.getBoundingClientRect();
    const sy=snapY(e.clientY-rect.top);
    const sx=Math.max(0,e.clientX-rect.left-110);
    let text='',color=dragColor||COMFORT_COLORS[0];
    if(type.startsWith('preset:')){
      const idx=parseInt(type.split(':')[1]);
      const p=presets[idx];
      if(p){text=p.text;color=ALL_COLORS.find(c=>c.hex===p.color)||color;}
    }
    createBlock(sx,sy,text,color);
    checkAndUpdateStreak();
    playPlaceSound();
    dragColor=null;
  });
}

function snapY(y){return Math.max(0,Math.round(y/ROW_H)*ROW_H)}

// ═══════════════════════════════
//  CREATE BLOCK
// ═══════════════════════════════
function createBlock(x,y,text,color){
  const c=color||COMFORT_COLORS[0];
  const grid=document.getElementById('grid-area');
  blockCnt++;
  const block=document.createElement('div');
  block.className='block';
  block.style.left=x+'px';block.style.top=y+'px';
  applyColor(block,c);

  const txt=document.createElement('div');
  txt.className='block-text';txt.contentEditable='true';txt.spellcheck=true;
  txt.dataset.ph='Type here…';txt.style.color=c.fg;
  if(text)txt.textContent=text;

  const btn=document.createElement('button');
  btn.className='block-menu-btn';btn.textContent='⋯';btn.style.color=c.fg;
  btn.addEventListener('click',e=>{e.stopPropagation();openDD(block,btn);});

  const rh=document.createElement('div');
  rh.className='block-resize';rh.style.color=c.fg;
  rh.addEventListener('mousedown',e=>{e.stopPropagation();resizeBlock(e,block);});

  block.appendChild(txt);block.appendChild(btn);block.appendChild(rh);
  block.addEventListener('mousedown',e=>{
    if(e.target===txt||e.target===btn||e.target===rh||e.target.closest('.block-dropdown'))return;
    dragBlock(e,block);
  });
  grid.appendChild(block);
  if(!text)setTimeout(()=>txt.focus(),40);
  return block;
}

function applyColor(block,c){
  block.style.background=c.hex;block.dataset.hex=c.hex;block.dataset.fg=c.fg;
  block.style.border=c.hex==='#FAFAE0'?'1px solid #ccc':'none';
  block.dataset.name=c.name||'';
  const txt=block.querySelector('.block-text');
  const btn=block.querySelector('.block-menu-btn');
  const rh=block.querySelector('.block-resize');
  if(txt)txt.style.color=c.fg;if(btn)btn.style.color=c.fg;if(rh)rh.style.color=c.fg;
}

// ═══════════════════════════════
//  DRAG BLOCK (expand on drag)
// ═══════════════════════════════
function dragBlock(e,block){
  e.preventDefault();
  const grid=document.getElementById('grid-area');
  const br=block.getBoundingClientRect();
  const ox=e.clientX-br.left,oy=e.clientY-br.top;
  const origH=block.style.height||'';
  const origW=block.style.width||'';

  block.classList.add('dragging');block.style.zIndex=100;

  const onMove=ev=>{
    const gr=grid.getBoundingClientRect();
    block.style.left=Math.max(0,ev.clientX-gr.left-ox)+'px';
    block.style.top=Math.max(0,ev.clientY-gr.top-oy)+'px';
  };
  const onUp=()=>{
    block.classList.remove('dragging');block.style.zIndex='';
    // Snap back — restore original size via transition
    if(origH)block.style.height=origH;
    if(origW)block.style.width=origW;
    block.style.top=snapY(parseFloat(block.style.top))+'px';
    document.removeEventListener('mousemove',onMove);
    document.removeEventListener('mouseup',onUp);
  };
  document.addEventListener('mousemove',onMove);
  document.addEventListener('mouseup',onUp);
}

// ═══════════════════════════════
//  RESIZE BLOCK
// ═══════════════════════════════
function resizeBlock(e,block){
  e.preventDefault();
  const sx=e.clientX,sy=e.clientY,sw=block.offsetWidth,sh=block.offsetHeight;
  const onMove=ev=>{
    block.style.width=Math.max(130,sw+(ev.clientX-sx))+'px';
    block.style.height=Math.max(ROW_H-6,sh+(ev.clientY-sy))+'px';
  };
  const onUp=()=>{
    const rows=Math.max(1,Math.round(block.offsetHeight/ROW_H));
    block.style.height=(rows*ROW_H-6)+'px';
    document.removeEventListener('mousemove',onMove);
    document.removeEventListener('mouseup',onUp);
  };
  document.addEventListener('mousemove',onMove);
  document.addEventListener('mouseup',onUp);
}

// ═══════════════════════════════
//  DROPDOWN
// ═══════════════════════════════
function openDD(block,btnEl){
  closeDD();
  const portal=document.getElementById('dd-portal');
  const dd=document.createElement('div');dd.className='block-dropdown';

  const ct=document.createElement('div');ct.className='dd-section-title';ct.textContent='Change Colour';dd.appendChild(ct);
  const swCat1=document.createElement('div');swCat1.className='dd-cat';swCat1.textContent='Comforting';dd.appendChild(swCat1);
  const sw1=document.createElement('div');sw1.className='dd-swatches';
  COMFORT_COLORS.forEach(col=>{sw1.appendChild(makeSwatch(col,block.dataset.hex===col.hex,()=>{applyColor(block,col);closeDD();}));});
  dd.appendChild(sw1);
  const swCat2=document.createElement('div');swCat2.className='dd-cat';swCat2.textContent='Strong';dd.appendChild(swCat2);
  const sw2=document.createElement('div');sw2.className='dd-swatches';
  STRONG_COLORS.forEach(col=>{sw2.appendChild(makeSwatch(col,block.dataset.hex===col.hex,()=>{applyColor(block,col);closeDD();}));});
  dd.appendChild(sw2);
  dd.appendChild(makeDivider());
  dd.appendChild(makeBtn('💾','Save Text as Preset',()=>{
    const t=block.querySelector('.block-text').textContent.trim();
    if(!t){showToast('Type something in the block first!');closeDD();return;}
    presets.push({text:t,color:block.dataset.hex});
    localStorage.setItem('tf_presets',JSON.stringify(presets));
    renderPresets();closeDD();showToast('Saved to Presets ✓');
  }));
  dd.appendChild(makeBtn('⧉','Duplicate Block',()=>{
    const t=block.querySelector('.block-text').textContent;
    const c=ALL_COLORS.find(x=>x.hex===block.dataset.hex)||COMFORT_COLORS[0];
    createBlock(parseFloat(block.style.left)+18,snapY(parseFloat(block.style.top)+ROW_H),t,c);closeDD();
  }));
  dd.appendChild(makeBtn('⬆','Bring to Front',()=>{block.style.zIndex=(parseInt(block.style.zIndex||10)+10)+'';closeDD();showToast('Brought to front');}));
  dd.appendChild(makeDivider());
  const db=makeBtn('🗑','Delete Block',()=>{block.remove();closeDD();});db.classList.add('danger');dd.appendChild(db);

  portal.appendChild(dd);
  const br=btnEl.getBoundingClientRect();
  let top=br.bottom+6,left=br.right-238;
  if(left<8)left=8;if(left+238>window.innerWidth-8)left=window.innerWidth-246;
  if(top+470>window.innerHeight-8)top=Math.max(8,br.top-476);
  dd.style.top=top+'px';dd.style.left=left+'px';
}

function makeSwatch(col,isCur,onClick){
  const s=document.createElement('div');s.className='dd-swatch'+(isCur?' cur-sw':'');
  s.style.background=col.hex;if(col.hex==='#FAFAE0')s.style.border='2px solid #ccc';s.title=col.name;
  s.addEventListener('click',e=>{e.stopPropagation();onClick();});return s;
}
function makeBtn(icon,label,onClick){
  const b=document.createElement('button');b.className='dd-btn';
  b.innerHTML=`<span class="dd-btn-icon">${icon}</span>${label}`;
  b.addEventListener('click',e=>{e.stopPropagation();onClick();});return b;
}
function makeDivider(){const d=document.createElement('hr');d.className='dd-divider';return d;}
function closeDD(){document.getElementById('dd-portal').innerHTML='';}

// ═══════════════════════════════
//  PRESETS
// ═══════════════════════════════
function renderPresets(){
  const list=document.getElementById('presets-list');list.innerHTML='';
  if(!presets.length){list.innerHTML='<div class="no-presets">No presets yet.<br>Use ⋯ on a block<br>to save typed text.</div>';return;}
  presets.forEach((p,i)=>{
    const item=document.createElement('div');item.className='preset-item';item.draggable=true;
    const dot=document.createElement('div');dot.className='preset-dot';dot.style.background=p.color;
    const txt=document.createElement('div');txt.className='preset-txt';txt.textContent=p.text;
    const del=document.createElement('button');del.className='preset-del';del.textContent='×';
    del.addEventListener('click',e=>{e.stopPropagation();presets.splice(i,1);localStorage.setItem('tf_presets',JSON.stringify(presets));renderPresets();});
    item.appendChild(dot);item.appendChild(txt);item.appendChild(del);
    item.addEventListener('dragstart',e=>{
      const c=ALL_COLORS.find(x=>x.hex===p.color)||COMFORT_COLORS[0];
      dragColor=c;
      e.dataTransfer.setData('text/plain',`preset:${i}`);e.dataTransfer.effectAllowed='copy';
    });
    item.addEventListener('dragend',()=>{dragColor=null;});
    list.appendChild(item);
  });
}

// ═══════════════════════════════
//  ANALYTICS
// ═══════════════════════════════
function getBlocks(){
  const blocks=document.querySelectorAll('#grid-area .block');
  return Array.from(blocks).map(b=>{
    const topPx=parseFloat(b.style.top)||0;
    const hPx=b.offsetHeight;
    const startHour=topPx/ROW_H;
    const durationHours=hPx/ROW_H;
    return{
      color:b.dataset.hex||'#A8D8EA',
      fg:b.dataset.fg||'#1C1C1C',
      name:b.dataset.name||b.dataset.hex||'Block',
      text:(b.querySelector('.block-text')||{}).textContent||'',
      startHour,durationHours,
      topPx,hPx
    };
  });
}

function renderAnalytics(){
  const inner=document.getElementById('analytics-inner');
  inner.innerHTML='';
  const blocks=getBlocks();

  inner.innerHTML=`
    <div class="an-title">Schedule Analytics</div>
    <div class="an-sub">Based on blocks currently on your workspace</div>
  `;

  if(!blocks.length){
    inner.innerHTML+=`<div class="an-card"><div class="an-empty"><div class="an-empty-icon">📊</div>No blocks on the workspace yet.<br>Head to <strong>Main</strong> and drag some colour blocks to build your schedule.</div></div>`;
    return;
  }

  // ── Stats ──
  const totalH=blocks.reduce((s,b)=>s+b.durationHours,0);
  const freeH=Math.max(0,24-totalH);
  const avgDur=totalH/blocks.length;

  // Find busiest hour
  const hourLoad=new Array(24).fill(0);
  blocks.forEach(b=>{
    const s=Math.floor(b.startHour),e=Math.min(24,Math.ceil(b.startHour+b.durationHours));
    for(let h=s;h<e;h++)hourLoad[h]++;
  });
  const busiestH=hourLoad.indexOf(Math.max(...hourLoad));

  inner.innerHTML+=`
    <div class="stat-row">
      <div class="stat-card"><div class="stat-val">${blocks.length}</div><div class="stat-lbl">Total Blocks</div></div>
      <div class="stat-card"><div class="stat-val">${totalH.toFixed(1)}h</div><div class="stat-lbl">Scheduled Time</div></div>
      <div class="stat-card"><div class="stat-val">${busiestH.toString().padStart(2,'0')}:00</div><div class="stat-lbl">Busiest Hour</div></div>
    </div>
  `;

  // ── Pie chart by colour ──
  const colorMap={};
  blocks.forEach(b=>{
    const key=b.color;
    if(!colorMap[key])colorMap[key]={color:b.color,fg:b.fg,name:b.name,hours:0,count:0};
    colorMap[key].hours+=b.durationHours;
    colorMap[key].count++;
  });
  // Add free time
  if(freeH>0) colorMap['__free']={color:'#E8E0D8',fg:'#9C8B82',name:'Free Time',hours:freeH,count:0};

  const slices=Object.values(colorMap).sort((a,b2)=>b2.hours-a.hours);
  const totalAll=slices.reduce((s,x)=>s+x.hours,0);

  const anGrid=document.createElement('div');anGrid.className='an-grid';

  // Pie card
  const pieCard=document.createElement('div');pieCard.className='an-card';
  pieCard.innerHTML=`<div class="an-card-title">Time Distribution</div><div class="an-card-sub">Hours allocated per colour block</div>`;

  const pieWrap=document.createElement('div');pieWrap.id='pie-wrap';

  const canvas=document.createElement('canvas');
  canvas.id='pie-canvas';canvas.width=160;canvas.height=160;pieWrap.appendChild(canvas);

  const legend=document.createElement('div');legend.id='pie-legend';
  slices.forEach(s=>{
    const pct=(s.hours/totalAll*100).toFixed(1);
    const li=document.createElement('div');li.className='legend-item';
    li.innerHTML=`<div class="legend-dot" style="background:${s.color}"></div><span class="legend-label">${s.name}</span><span class="legend-pct">${pct}%</span><span class="legend-hrs">${s.hours.toFixed(1)}h</span>`;
    legend.appendChild(li);
  });
  pieWrap.appendChild(legend);
  pieCard.appendChild(pieWrap);

  // Bar chart card (blocks by hour)
  const barCard=document.createElement('div');barCard.className='an-card';
  barCard.innerHTML=`<div class="an-card-title">Hourly Load</div><div class="an-card-sub">Number of blocks per hour</div>`;
  const barChart=document.createElement('div');barChart.id='bar-chart';
  const maxLoad=Math.max(...hourLoad,1);
  // Only show hours 6–23
  for(let h=0;h<24;h++){
    const col=document.createElement('div');col.className='bar-col';
    const fill=document.createElement('div');fill.className='bar-fill';
    fill.style.background=hourLoad[h]>0?`hsl(${28+h*6},60%,${55-hourLoad[h]*4}%)`:'#ede8e2';
    const pctH=(hourLoad[h]/maxLoad*90);
    fill.style.height=pctH+'%';
    fill.setAttribute('data-tip',`${h.toString().padStart(2,'0')}:00 · ${hourLoad[h]} block${hourLoad[h]!==1?'s':''}`);
    const lbl=document.createElement('div');lbl.className='bar-lbl';lbl.textContent=h%3===0?h.toString().padStart(2,'0'):'';
    col.appendChild(fill);col.appendChild(lbl);barChart.appendChild(col);
  }
  barCard.appendChild(barChart);

  anGrid.appendChild(pieCard);
  anGrid.appendChild(barCard);

  // Block list card
  const listCard=document.createElement('div');listCard.className='an-card full';
  listCard.innerHTML=`<div class="an-card-title">Block Summary</div><div class="an-card-sub">All scheduled blocks on workspace</div>`;
  const tbl=document.createElement('table');
  tbl.style.cssText='width:100%;border-collapse:collapse;font-size:12px';
  tbl.innerHTML=`<thead><tr style="text-align:left;border-bottom:1px solid #ede8e2">
    <th style="padding:6px 10px;font-weight:600;color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:.08em">Colour</th>
    <th style="padding:6px 10px;font-weight:600;color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:.08em">Text</th>
    <th style="padding:6px 10px;font-weight:600;color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:.08em">Start</th>
    <th style="padding:6px 10px;font-weight:600;color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:.08em">Duration</th>
  </tr></thead>`;
  const tbody=document.createElement('tbody');
  blocks.forEach(b=>{
    const hr=Math.floor(b.startHour),mn=Math.round((b.startHour-hr)*60);
    const timeStr=`${hr.toString().padStart(2,'0')}:${mn.toString().padStart(2,'0')}`;
    const dur=b.durationHours>=1?`${b.durationHours.toFixed(1)}h`:`${Math.round(b.durationHours*60)}m`;
    const tr=document.createElement('tr');
    tr.style.borderBottom='1px solid #f5f0e8';
    tr.innerHTML=`
      <td style="padding:7px 10px"><span style="display:inline-block;width:14px;height:14px;border-radius:3px;background:${b.color};vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,.08)"></span>${b.name}</td>
      <td style="padding:7px 10px;color:var(--muted)">${b.text||'—'}</td>
      <td style="padding:7px 10px;font-family:'DM Mono',monospace;font-size:11px">${timeStr}</td>
      <td style="padding:7px 10px;font-family:'DM Mono',monospace;font-size:11px">${dur}</td>
    `;
    tbody.appendChild(tr);
  });
  tbl.appendChild(tbody);listCard.appendChild(tbl);
  anGrid.appendChild(listCard);
  inner.appendChild(anGrid);

  // Draw pie with requestAnimationFrame
  requestAnimationFrame(()=>drawPie(canvas,slices,totalAll));
}

function drawPie(canvas,slices,total){
  const ctx=canvas.getContext('2d');
  const cx=80,cy=80,r=70;
  ctx.clearRect(0,0,160,160);
  let angle=-Math.PI/2;
  slices.forEach(s=>{
    const sweep=s.hours/total*Math.PI*2;
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,angle,angle+sweep);ctx.closePath();
    ctx.fillStyle=s.color;ctx.fill();
    ctx.strokeStyle='#fff';ctx.lineWidth=2;ctx.stroke();
    angle+=sweep;
  });
  // Centre hole
  ctx.beginPath();ctx.arc(cx,cy,r*0.42,0,Math.PI*2);ctx.fillStyle='#fff';ctx.fill();
  // Centre label
  ctx.fillStyle='#9C8B82';ctx.textAlign='center';ctx.font='bold 11px DM Sans, sans-serif';
  ctx.fillText(slices.length-1+(slices.find(s=>s.color==='#E8E0D8')?0:0)+' blocks',cx,cy+4);
}

// ═══════════════════════════════
//  TOAST
// ═══════════════════════════════
function showToast(msg){
  const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2600);
}

init();
</script>
